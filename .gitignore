# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment files
.env
.env.*
!.env.example

# Jupyter
.ipynb_checkpoints/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/

# Raw data should not be tracked by default
data/raw/*
!data/raw/.gitkeep

# Processed data should not be tracked by default
data/processed/*

# Allow official cookbook SQLite databases
!data/processed/sql/
!data/processed/sql/*.sqlite

# Ignore other local database formats by default
*.db
*.sqlite3

# But still allow cookbook SQLite files
!data/processed/sql/*.sqlite